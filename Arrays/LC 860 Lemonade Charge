 class Solution {
public:
    bool lemonadeChange(vector<int>& bills) {
       int fiveDollars =0,tenDollars=0;
       for(int x:bills){
        if(x==5) fiveDollars++;
        else if(x==10){
            if(fiveDollars>=1){
                fiveDollars--;
                tenDollars++;
              }
              else{
                return false;
              }
        }
        else{
            if(fiveDollars>0 && tenDollars>0){
                fiveDollars--;
                tenDollars--;
            }
            else if(fiveDollars>2){
                fiveDollars -=3;
            }
            else{
                return false;
            }

        }
       }
       return true;
    }
};