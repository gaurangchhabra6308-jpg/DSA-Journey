   class Solution {
public:
    int trap(vector<int>& height) {
        int start=0;
        int end= height.size()-1;
        int leftmax=0;
        int rightmax=0;
        int totalwater=0;

        while(start<end){
            leftmax= max(leftmax,height[start]);
            rightmax=max(rightmax,height[end]);

            if(rightmax>leftmax){
               totalwater+= leftmax-height[start];
               start++;
            }
            else{
                totalwater+= rightmax-height[end];
                end--;
            }
        }
        return totalwater;
    }
};